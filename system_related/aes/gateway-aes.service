[Unit]
Description=Zero Axis Gateway Analytics Engine
After=gateway-network-apply.service
Wants=gateway-network-apply.service

[Service]
Type=simple
WorkingDirectory=/opt/gateway/software/aes
# ExecStart=python3 -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
